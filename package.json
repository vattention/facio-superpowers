{
  "name": "@vattention/facio-superpowers",
  "version": "2.6.0",
  "description": "Documentation management for AI-assisted development with Claude Code and Cursor",
  "main": "cli.js",
  "bin": {
    "facio-superpowers": "./cli.js"
  },
  "scripts": {
    "test": "node tests/harness-merge/test.js",
    "test:generator": "node --test src/generate-spec-html/*.test.mjs",
    "test:server": "node --test services/spec-preview-server/*.test.mjs",
    "build:generator": "node scripts/build-generator.mjs",
    "version:patch": "npm version patch -m 'chore: bump version to %s'",
    "version:minor": "npm version minor -m 'chore: bump version to %s'",
    "version:major": "npm version major -m 'chore: bump version to %s'",
    "prepublishOnly": "npm run build:generator",
    "release": "git push && git push --tags"
  },
  "dependencies": {
    "markdown-it": "^14.1.0",
    "markdown-it-anchor": "^9.0.0",
    "markdown-it-attrs": "^4.3.0",
    "markdown-it-task-lists": "^2.1.1",
    "shiki": "^1.22.0"
  },
  "devDependencies": {
    "esbuild": "^0.24.0"
  },
  "keywords": [
    "claude-code",
    "cursor",
    "ai-assisted-development",
    "documentation",
    "adr",
    "architecture-decision-records",
    "superpowers",
    "ai-tools"
  ],
  "author": "Facio Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vattention/facio-superpowers.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "bugs": {
    "url": "https://github.com/vattention/facio-superpowers/issues"
  },
  "homepage": "https://github.com/vattention/facio-superpowers#readme",
  "engines": {
    "node": ">=14.0.0"
  },
  "files": [
    "cli.js",
    "skills/",
    "templates/",
    "README-FACIO.md"
  ]
}
